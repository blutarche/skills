# OMC / Claude Code runtime state — not part of the skills collection.
# Track the repo's own working config (project skills + shared settings); ignore the rest.
.omc/
.claude/*
!.claude/skills/
!.claude/settings.json

# macOS
.DS_Store

# Editor/OS cruft
*.swp
*~
.idea/
.vscode/

# Python bytecode (skill scripts generate this)
__pycache__/
*.pyc

# Skill eval scaffolding / run artifacts — not part of the collection
*-workspace/
